{"action": "edit", "code": "def extend_path_to_boundary(input_grid: np.ndarray, cur: Tuple[int, int], dir: Tuple[int, int]) -> np.ndarray:\n    while True:\n        x = cur[0] + dir[0]\n        y = cur[1] + dir[1]\n        if x < 0 or x >= input_grid.shape[0] or y < 0 or (y >= input_grid.shape[1]):\n            break\n        if input_grid[x][y] == black:\n            break\n        input_grid[cur[0]][cur[1]] = green\n        cur = (x, y)\n    return input_grid\ndef get_teal_direction(start: Tuple[int, int], input_grid: np.ndarray) -> Tuple[int, int]:\n    for i in range(-1, 2):\n        for j in range(-1, 2):\n            if i == 0 and j == 0:\n                continue\n            x = start[0] + i\n            y = start[1] + j\n            if x < 0 or x >= input_grid.shape[0] or y < 0 or (y >= input_grid.shape[1]):\n                continue\n            if input_grid[x][y] == teal:\n                return (i, j)\n    return None\ndef get_start_position(input_grid: np.ndarray) -> Tuple[int, int]:\n    for i in range(input_grid.shape[0]):\n        if input_grid[i][0] == teal:\n            return (i, 0)\n        elif input_grid[i][input_grid.shape[1] - 1] == teal:\n            return (i, input_grid.shape[1] - 1)\n    for j in range(input_grid.shape[1]):\n        if input_grid[0][j] == teal:\n            return (0, j)\n        elif input_grid[input_grid.shape[0] - 1][j] == teal:\n            return (input_grid.shape[0] - 1, j)\n    return None\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    start = get_start_position(input_grid)\n    dir = get_teal_direction(start, input_grid)\n    out_grid, cur = change_color(start, dir, input_grid)\n    new_dir = change_to_new_diagonal_direction(out_grid, cur, dir)\n    out_grid = extend_path_to_boundary(out_grid, cur, new_dir)\n    return out_grid\ndef change_to_new_diagonal_direction(input_grid: np.ndarray, cur: Tuple[int, int], dir: Tuple[int, int]) -> Tuple[int, int]:\n    if dir == (1, 1):\n        if cur[0] == input_grid