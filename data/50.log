{"action": "input", "code": "def is_block_below_black(input_grid: np.ndarray, x: int, y: int) -> bool:\n    if x == input_grid.shape[0] - 1:\n        return False\n    return input_grid[x + 1][y] == black\ndef is_block_above_black(input_grid: np.ndarray, x: int, y: int) -> bool:\n    if x == 0:\n        return False\n    return input_grid[x - 1][y] == black\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    color = find_least_common_color(input_grid)\n    x, y = find_color_index(input_grid, color)\n    if is_block_above_black(input_grid, x, y):\n        output_grid = fill_black_blocks_below(input_grid, x, y, color)\n    elif is_block_left_black(input_grid, x, y):\n        output_grid = fill_black_blocks_right(input_grid, x, y, color)\n    elif is_block_below_black(input_grid, x, y):\n        output_grid = fill_black_blocks_above(input_grid, x, y, color)\n    else:\n        output_grid = fill_black_blocks_left(input_grid, x, y, color)\n    return output_grid\ndef fill_black_blocks_below(input_grid: np.ndarray, x: int, y: int, color: int) -> np.ndarray:\n    for i in range(x + 1, input_grid.shape[0]):\n        if input_grid[i][y] == black:\n            input_grid[i][y] = color\n        else:\n            break\n    return input_grid\ndef fill_black_blocks_right(input_grid: np.ndarray, x: int, y: int, color: int) -> np.ndarray:\n    for i in range(y + 1, input_grid.shape[1]):\n        if input_grid[x][i] == black:\n            input_grid[x][i] = color\n        else:\n            break\n    return input_grid\ndef fill_black_blocks_left(input_grid: np.ndarray, x: int, y: int, color: int) -> np.ndarray:\n    for i in range(y - 1, -1, -1):\n        if input_grid[x][i] == black:\n            input_grid[x][i] = color\n        else:\n            break\n    return input_grid\ndef find_least_common_color(input_grid: np.ndarray) -> int:\n    color_counts = np.bincount(input_grid.flatten())\n    least_common_color = np.argmin(color_counts)\n    return least_common_color\ndef f