{"action": "edit", "code": "def is_block_below_black(input_grid: np.ndarray, x: int, y: int) -> bool:\n    if x == input_grid.shape[0] - 1:\n        return False\n    return input_grid[x + 1][y] == black\ndef is_block_above_black(input_grid: np.ndarray, x: int, y: int) -> bool:\n    if x == 0:\n        return False\n    return input_grid[x - 1][y] == black\ndef convert_black_to_color(input_color: int, target_color: int) -> int:\n    if input_color == black:\n        return target_color\n    else:\n        return input_color\ndef find_blocks_below(input_grid: np.ndarray, x: int, y: int) -> List[Tuple[int, int]]:\n    block_list = []\n    for i in range(x + 1, input_grid.shape[0]):\n        if input_grid[i][y] != black:\n            break\n        block_list.append((i, y))\n    return block_list\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    color = find_least_common_color(input_grid)\n    x, y = find_color_index(input_grid, color)\n    if is_block_above_black(input_grid, x, y):\n        output_grid = fill_black_blocks_below(input_grid, x, y, color)\n    elif is_block_left_black(input_grid, x, y):\n        output_grid = fill_black_blocks_right(input_grid, x, y, color)\n    elif is_block_below_black(input_grid, x, y):\n        output_grid = fill_black_blocks_above(input_grid, x, y, color)\n    else:\n        output_grid = fill_black_blocks_left(input_grid, x, y, color)\n    return output_grid\ndef fill_black_blocks_below(input_grid: np.ndarray, x: int, y: int, color: int) -> np.ndarray:\n    block_list = find_blocks_below(input_grid, x, y)\n    for x, y in block_list:\n        input_grid[x][y] = convert_black_to_color(input_grid[x][y], color)\n    return input_grid\ndef fill_black_blocks_right(input_grid: np.ndarray, x: int, y: int, color: int) -> np.ndarray:\n    for i in range(y + 1, input_grid.shape[1]):\n        if input_grid[x][i] == black:\n            input_grid[x][i] = color\n        else:\n            break\n    return input_grid\ndef fill_black_blocks_left(input_grid: np.ndarray, x: int, y: int, color: int) -> np.ndarray:\n    for i in range(y - 1, -1, -1):\n        if input_grid[x][i] == black:\n            input_grid[x][i] = color\n        else:\n            break\n    return input_grid\n# find the color with the fewest occurrences in the grid\ndef find_least_common_color(input_grid: np.ndarray) -> int:\n    unique, counts = np.unique(input_grid, return_counts=True)\n    color_count_dict = dict(zip(unique, counts))\n    return min(color_count_dict, key=color_count_dict.get)\ndef find_color_index(input_grid: np.ndarray, color: int) -> Tuple[int, int]:\n    indices = np.where(input_grid == color)\n    return (indices[0][0], indices[1][0])\ndef fill_black_blocks_above(input_grid: np.ndarray, x: int, y: int, color: int) -> np.ndarray:\n    for i in range(x - 1, -1, -1):\n        if input_grid[i][y] == black:\n            input_grid[i][y] = color\n        else:\n            break\n    return input_grid\ndef is_block_left_black(input_grid: np.ndarray, x: int, y: int) -> bool:\n    if y == 0:\n        return False\n    return input_grid[x][y - 1] == black", "user_code": "def main(input_grid: np.ndarray) -> np.ndarray:\n\tcolor = `find the color with the fewest occurrences in the grid`(input_grid)\n\tx, y = `find the index of a block in the grid that has the corresponding color`(input_grid, color)\n\tif `is the block above the corresponding block black`(input_grid, x, y):\n\t\toutput_grid = `fill black blocks below the corresponding block with corresponding color`(input_grid, x, y, color)\n\telif `is the block left to the corresponding block black`(input_grid, x, y):\n\t\toutput_grid = `fill black blocks right to the corresponding block with corresponding color`(input_grid, x, y, color)\n\telif `is the block below the corresponding block black`(input_grid, x, y):\n\t\toutput_grid = `fill black blocks above the corresponding block with corresponding color`(input_grid, x, y, color)\n\telse:\n\t\toutput_grid = `fill black