{"action": "input", "code": "def main(input_grid: np.ndarray) -> np.ndarray:\n    special_pixel = find_special_pixel(input_grid)\n    output_grid = input_grid.copy()\n    output_grid = change_special_pixel_to_black(special_pixel, output_grid)\n    symmetrical_axis = find_symmetrical_axis(output_grid)\n    output_grid = stain_black_pixels(symmetrical_axis, output_grid)\n    return output_grid\ndef find_special_pixel(input_grid: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    Finds a relatively small number of non-black pixel's index in the input_grid.\n\n    Args:\n    input_grid: A numpy array representing the input grid.\n\n    Returns:\n    A tuple representing the index of the special pixel.\n    \"\"\"\n    non_black_pixels = np.where(input_grid != black)\n    special_pixel_index = np.argmin(np.sum(non_black_pixels, axis=0))\n    special_pixel = (non_black_pixels[0][special_pixel_index], non_black_pixels[1][special_pixel_index])\n    return special_pixel\ndef change_special_pixel_to_black(special_pixel: Tuple[int, int], input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Changes the special pixel in the input grid to black.\n\n    Args:\n    special_pixel: A tuple representing the index of the special pixel.\n    input_grid: A numpy array representing the input grid.\n\n    Returns:\n    A numpy array representing the output grid with the special pixel changed to black.\n    \"\"\"\n    output_grid = input_grid.copy()\n    output_grid[special_pixel] = black\n    return output_grid\ndef stain_black_pixels(symmetrical_axis: int, output_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Stains some black pixels according to the symmetry axis in the output_grid.\n\n    Args:\n    symmetrical_axis: An integer representing the symmetrical axis of the non-black pixel.\n    output_grid: A numpy array representing the output grid.\n\n    Returns:\n    A numpy array representing the output grid with some black pixels stained.\n    \"\"\"\n    output_grid[symmetrical_axis:, :] = black\n    return output_grid\ndef find_symmetrical_axis(output_grid: np.ndarray) -> int:\n    \"\"\"\n    Finds the symmetrical axis of the non-black pixel in the output_grid.\n\n    Args:\n    output_grid: A numpy array representing the output grid.\n\n    Returns:\n    An integer representing the symmetrical axis of the non-black pixel.\n    \"\"\"\n    non_black_pixels = np.where(output_grid != black)\n    x_min, y_min = np.min(non_black_pixels, axis=1)\n    x_max, y_max = np.max(non_black_pixels, axis=1)\n    center_x, center_y = ((x_min + x_max) // 2, (y_min + y_max) // 2)\n    symmetrical_axis = 0\n    for i in range(center_x, x_max + 1):\n        if output_grid[i, center_y] != black:\n            symmetrical_axis = i\n            break\n    return symmetrical_axis", "user_code": "def main(input_grid:np.ndarray) -> np.ndarray:\n    special_pixel = `Find a relatively small number of non-black pixel's index in the input_grid`(input_grid)\n    output_grid = input_grid.copy()\n    output_grid = `change the special_pixel in the output_grid to black`(special_pixel, output_grid)\n    symmetrical_axis = `find the symmetrical_axis of the non-black pixel in the output_grid`(output_grid)\n    output_grid = `Stain some black pixels according to the symmetry axis in the output_grid`(symmetrical_axis, output_grid)\n    return output_grid", "gpt_code": "def find_special_pixel(input_grid: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    Finds a relatively small number of non-black pixel's index in the input_grid.\n\n    Args:\n    input_grid: A numpy array representing the input grid.\n\n    Returns:\n    A tuple representing the index of the special pixel.\n    \"\"\"\n    non_black_pixels = np.where(input_grid != black)\n    special_pixel_index = np.argmin(np.sum(non_black_pixels, axis=0))\n    special_pixel = (non_black_pixels[0][special_pixel_index], non_black_pixels[1][special_pixel_index])\n    return special_pixel\ndef change_special_pixel_to_black(special_pixel: Tuple[int, int], input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Changes the special pixel in the input grid to black.\n\n    Args:\n    special_pixel: A tuple representing the index of the special pixel.\n    input_grid: A numpy array representing the input grid.\n\n    Returns:\n    A numpy array representing the output grid with the special pixel changed to black.\n    \"\"\"\n    output_grid = input_grid.copy()\n    output_grid[special_pixel] = black\n    return output_grid\ndef stain_black_pixels(symmetrical_axis: int, output_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Stains some black pixels according to the symmetry axis in the output_grid.\n\n    Args:\n    symmetrical_axis: An integer representing the symmetrical axis of the non-black pixel.\n    output_grid: A numpy array representing the output grid.\n\n    Returns:\n    A numpy array representing the output grid with some black pixels stained.\n    \"\"\"\n    output_grid[symmetrical_axis:, :] = black\n    return output_grid\ndef find_symmetrical_axis(output_grid: np.ndarray) -> int:\n    \"\"\"\n    Finds the symmetrical axis of the non-black pixel in the output_grid.\n\n    Args:\n    output_grid: A numpy array representing the output grid.\n\n    Returns:\n    An integer representing the symmetrical axis of the non-black pixel.\n    \"\"\"\n    non_black_pixels = np.where(output_grid != black)\n    x_min, y_min = np.min(non_black_pixels, axis=1)\n    x_max, y_max = np.max(non_black_pixels, axis=1)\n    center_x, center_y = ((x_min + x_max) // 2, (y_min + y_max) // 2)\n    symmetrical_axis = 0\n    for i in range(center_x, x_max + 1):\n        if output_grid[i, center_y] != black:\n            symmetrical_axis = i\n            break\n    return symmetrical_axis", "holes": {"find_special_pixel": "Find a relatively small number of non-black pixel's index in the input_grid", "change_special_pixel_to_black": "change the special_pixel in the output_grid to black", "stain_black_pixels": "Stain some black pixels according to the symmetry axis in the output_grid", "find_symmetrical_axis": "find the symmetrical_axis of the non-black pixel in the output_grid"}}
{"action": "edit", "code": "def stain_black_pixels(symmetrical_axis: str, output_grid: np.ndarray) -> np.ndarray:\n    if symmetrical_axis == 'horizontal':\n        output_grid = np.vstack((output_grid[0:output_grid.shape[0] // 2], np.flipud(output_grid[0:output_grid.shape[0] // 2])))\n    elif symmetrical_axis == 'vertical':\n        output_grid = np.hstack((output_grid[:, 0:output_grid.shape[1] // 2], np.fliplr(output_grid[:, 0:output_grid.shape[1] // 2])))\n    return output_grid\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    special_pixel = find_non_black_pixels(input_grid)\n    output_grid = input_grid.copy()\n    output_grid = change_special_pixel_to_black(special_pixel, output_grid)\n    symmetrical_axis = find_symmetrical_axis(output_grid)\n    output_grid = stain_black_pixels(symmetrical_axis, output_grid)\n    return output_grid\ndef change_special_pixel_to_black(special_pixel: Tuple[int, int], output_grid: np.ndarray) -> np.ndarray:\n    i, j = special_pixel\n    output_grid[i][j] = black\n    return output_grid\ndef find_non_black_pixels(input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    non_black_pixels = []\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] != black:\n                non_black_pixels.append((i, j))\n    return non_black_pixels\ndef find_symmetrical_axis(output_grid: np.ndarray, special_pixel: Tuple[int, int]) -> str:\n    i, j = special_pixel\n    if i == output_grid.shape[0] // 2:\n        return 'horizontal'\n    elif j == output_grid.shape[1] // 2:\n        return 'vertical'\n    else:\n        return 'no symmetrical axis'", "user_code": "def main(input_grid:np.ndarray) -> np.ndarray:\n    special_pixel = `Find all the relatively small number of non-black pixels' index in the input_grid`(input_grid)\n    output_grid = input_grid.copy()\n    output_grid = `change the special_pixel in the output_grid to black`(special_pixel, output_grid)\n    symmetrical_axis = `find the symmetrical_axis of the non-black pixel in the output_grid`(output_grid)\n    output_grid = `Stain some black pixels according to the symmetry axis in the output_grid`(symmetrical_axis, output_grid)\n    return output_grid", "gpt_code": "def stain_black_pixels(symmetrical_axis: str, output_grid: np.ndarray) -> np.ndarray:\n    if symmetrical_axis == 'horizontal':\n        output_grid = np.vstack((output_grid[0:output_grid.shape[0] // 2], np.flipud(output_grid[0:output_grid.shape[0] // 2])))\n    elif symmetrical_axis == 'vertical':\n        output_grid = np.hstack((output_grid[:, 0:output_grid.shape[1] // 2], np.fliplr(output_grid[:, 0:output_grid.shape[1] // 2])))\n    return output_grid\ndef change_special_pixel_to_black(special_pixel: Tuple[int, int], output_grid: np.ndarray) -> np.ndarray:\n    i, j = special_pixel\n    output_grid[i][j] = black\n    return output_grid\ndef find_non_black_pixels(input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    non_black_pixels = []\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] != black:\n                non_black_pixels.append((i, j))\n    return non_black_pixels\ndef find_symmetrical_axis(output_grid: np.ndarray, special_pixel: Tuple[int, int]) -> str:\n    i, j = special_pixel\n    if i == output_grid.shape[0] // 2:\n        return 'horizontal'\n    elif j == output_grid.shape[1] // 2:\n        return 'vertical'\n    else:\n        return 'no symmetrical axis'", "holes": {"stain_black_pixels": "Stain some black pixels according to the symmetry axis in the output_grid", "change_special_pixel_to_black": "change the special_pixel in the output_grid to black", "find_non_black_pixels": "Find all the relatively small number of non-black pixels' index in the input_grid", "find_symmetrical_axis": "find the symmetrical_axis of the non-black pixel in the output_grid"}}
{"action": "edit", "code": "def main(input_grid: np.ndarray) -> np.ndarray:\n    special_pixels = find_non_black_pixels(input_grid)\n    output_grid = input_grid.copy()\n    output_grid = change_special_pixel_to_black(special_pixel, output_grid)\n    symmetrical_axis = find_symmetrical_axis(output_grid)\n    output_grid = stain_pixels_according_to_symmetry_axis(symmetrical_axis, output_grid)\n    return output_grid\ndef change_special_pixel_to_black(special_pixel: Tuple[int, int], output_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Changes the pixel at the given index to black.\n\n    Args:\n    - special_pixel (Tuple[int, int]): The index of the pixel to be changed.\n    - output_grid (np.ndarray): The input grid.\n\n    Returns:\n    - np.ndarray: The output grid with the pixel at the given index changed to black.\n    \"\"\"\n    output_grid[special_pixel] = black\n    return output_grid\ndef stain_pixels_according_to_symmetry_axis(symmetry_axis: str, output_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Stains some black pixels according to the symmetry axis in the output grid.\n\n    Args:\n    - symmetry_axis (str): A string representing the symmetry axis.\n    - output_grid (np.ndarray): The output grid.\n\n    Returns:\n    - np.ndarray: The output grid with some black pixels stained according to the symmetry axis.\n    \"\"\"\n    if symmetry_axis == 'horizontal':\n        output_grid[:, ::-1] = black\n    elif symmetry_axis == 'vertical':\n        output_grid[::-1, :] = black\n    elif symmetry_axis == 'diagonal':\n        output_grid = np.rot90(output_grid, k=3)\n        output_grid = np.tril(output_grid, k=-1)\n        output_grid = np.rot90(output_grid, k=1)\n        output_grid = np.tril(output_grid, k=-1)\n    return output_grid\ndef find_non_black_pixels(input_grid: np.ndarray, threshold: int=10) -> List[Tuple[int, int]]:\n    \"\"\"\n    Finds the indices of non-black pixels in the input grid.\n\n    Args:\n    - input_grid (np.ndarray): The input grid.\n    - threshold (int): The maximum number of non-black pixels to return.\n\n    Returns:\n    - List[Tuple[int, int]]: A list of tuples representing the indices of non-black pixels.\n    \"\"\"\n    non_black_pixels = np.where(input_grid != black)\n    non_black_pixels_indices = list(zip(non_black_pixels[0], non_black_pixels[1]))\n    if len(non_black_pixels_indices) > threshold:\n        non_black_pixels_indices = non_black_pixels_indices[:threshold]\n    return non_black_pixels_indices\ndef find_symmetrical_axis(output_grid: np.ndarray, non_black_pixel: Tuple[int, int]) -> str:\n    \"\"\"\n    Finds the symmetrical axis of the non-black pixel in the output grid.\n\n    Args:\n    - output_grid (np.ndarray): The output grid.\n    - non_black_pixel (Tuple[int, int]): The index of the non-black pixel.\n\n    Returns:\n    - str: A string representing the symmetrical axis of the non-black pixel.\n    \"\"\"\n    row, col = non_black_pixel\n    if output_grid[row, col] == blue:\n        return 'horizontal'\n    elif output_grid[row, col] == red:\n        return 'vertical'\n    elif output_grid[row, col] == green:\n        return 'diagonal'\n    else:\n        return 'unknown'", "user_code": "def main(input_grid:np.ndarray) -> np.ndarray:\n    special_pixels = `Find relatively small number of non-black pixels' index in the input_grid`(input_grid)\n    output_grid = input_grid.copy()\n    output_grid = `change the special_pixel in the output_grid to black`(special_pixel, output_grid)\n    symmetrical_axis = `find the symmetrical_axis of the non-black pixel in the output_grid`(output_grid)\n    output_grid = `Stain some black pixels according to the symmetry axis in the output_grid`(symmetrical_axis, output_grid)\n    return output_grid", "gpt_code": "def change_special_pixel_to_black(special_pixel: Tuple[int, int], output_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Changes the pixel at the given index to black.\n\n    Args:\n    - special_pixel (Tuple[int, int]): The index of the pixel to be changed.\n    - output_grid (np.ndarray): The input grid.\n\n    Returns:\n    - np.ndarray: The output grid with the pixel at the given index changed to black.\n    \"\"\"\n    output_grid[special_pixel] = black\n    return output_grid\ndef stain_pixels_according_to_symmetry_axis(symmetry_axis: str, output_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Stains some black pixels according to the symmetry axis in the output grid.\n\n    Args:\n    - symmetry_axis (str): A string representing the symmetry axis.\n    - output_grid (np.ndarray): The output grid.\n\n    Returns:\n    - np.ndarray: The output grid with some black pixels stained according to the symmetry axis.\n    \"\"\"\n    if symmetry_axis == 'horizontal':\n        output_grid[:, ::-1] = black\n    elif symmetry_axis == 'vertical':\n        output_grid[::-1, :] = black\n    elif symmetry_axis == 'diagonal':\n        output_grid = np.rot90(output_grid, k=3)\n        output_grid = np.tril(output_grid, k=-1)\n        output_grid = np.rot90(output_grid, k=1)\n        output_grid = np.tril(output_grid, k=-1)\n    return output_grid\ndef find_non_black_pixels(input_grid: np.ndarray, threshold: int=10) -> List[Tuple[int, int]]:\n    \"\"\"\n    Finds the indices of non-black pixels in the input grid.\n\n    Args:\n    - input_grid (np.ndarray): The input grid.\n    - threshold (int): The maximum number of non-black pixels to return.\n\n    Returns:\n    - List[Tuple[int, int]]: A list of tuples representing the indices of non-black pixels.\n    \"\"\"\n    non_black_pixels = np.where(input_grid != black)\n    non_black_pixels_indices = list(zip(non_black_pixels[0], non_black_pixels[1]))\n    if len(non_black_pixels_indices) > threshold:\n        non_black_pixels_indices = non_black_pixels_indices[:threshold]\n    return non_black_pixels_indices\ndef find_symmetrical_axis(output_grid: np.ndarray, non_black_pixel: Tuple[int, int]) -> str:\n    \"\"\"\n    Finds the symmetrical axis of the non-black pixel in the output grid.\n\n    Args:\n    - output_grid (np.ndarray): The output grid.\n    - non_black_pixel (Tuple[int, int]): The index of the non-black pixel.\n\n    Returns:\n    - str: A string representing the symmetrical axis of the non-black pixel.\n    \"\"\"\n    row, col = non_black_pixel\n    if output_grid[row, col] == blue:\n        return 'horizontal'\n    elif output_grid[row, col] == red:\n        return 'vertical'\n    elif output_grid[row, col] == green:\n        return 'diagonal'\n    else:\n        return 'unknown'", "holes": {"change_special_pixel_to_black": "change the special_pixel in the output_grid to black", "stain_pixels_according_to_symmetry_axis": "Stain some black pixels according to the symmetry axis in the output_grid", "find_non_black_pixels": "Find relatively small number of non-black pixels' index in the input_grid", "find_symmetrical_axis": "find the symmetrical_axis of the non-black pixel in the output_grid"}}
{"action": "edit", "code": "def find_pixels_with_given_amount(num: int, input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    pixels = []\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] != black:\n                if input_grid.tolist().count(input_grid[i][j]) == num:\n                    pixels.append((i, j))\n    return pixels\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    non_black_nums = get_non_black_pixels(input_grid)\n    num = non_black_nums[-1]\n    special_pixels = find_pixels_with_given_amount(num, input_grid)\n    output_grid = input_grid.copy()\n    output_grid = change_special_pixel_to_black(special_pixel, output_grid)\n    symmetrical_axis = find_symmetrical_axis(output_grid)\n    output_grid = stain_black_pixels(symmetrical_axis, output_grid)\n    return output_grid\ndef change_special_pixel_to_black(special_pixel: Tuple[int, int], output_grid: np.ndarray) -> np.ndarray:\n    i, j = special_pixel\n    output_grid[i][j] = black\n    return output_grid\ndef get_non_black_pixels(input_grid: np.ndarray) -> List[int]:\n    non_black_nums = [0] * 9\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] != black:\n                non_black_nums[input_grid[i][j] - 1] += 1\n    return non_black_nums\ndef stain_black_pixels(symmetrical_axis: int, output_grid: np.ndarray) -> np.ndarray:\n    if symmetrical_axis >= 0:\n        for i in range(output_grid.shape[0]):\n            for j in range(output_grid.shape[1]):\n                if i == symmetrical_axis or i + symmetrical_axis == output_grid.shape[0] - 1:\n                    output_grid[i][j] = black\n    else:\n        for i in range(output_grid.shape[0]):\n            for j in range(output_grid.shape[1]):\n                if j == abs(symmetrical_axis) or j + abs(symmetrical_axis) == output_grid.shape[1] - 1:\n                    output_grid[i][j] = black\n    return output_grid\ndef find_symmetrical_axis(output_grid: np.ndarray) -> int:\n    rows, cols = output_grid.shape\n    for i in range(rows):\n        for j in range(cols):\n            if output_grid[i][j] != black:\n                if i == j:\n                    return i\n                elif i + j == rows - 1:\n                    return -i\n    return 0", "user_code": "def main(input_grid:np.ndarray) -> np.ndarray:\n    non_black_nums = `Get the number of every kind of non-black pixles in the input_grid`(input_grid)\n    num = non_black_nums[-1]\n    special_pixels = `Find pixels's index whose amount == num in the input_grid`(num, input_grid)\n    output_grid = input_grid.copy()\n    output_grid = `change the special_pixel in the output_grid to black`(special_pixel, output_grid)\n    symmetrical_axis = `find the symmetrical_axis of the non-black pixel in the output_grid`(output_grid)\n    output_grid = `Stain some black pixels according to the symmetry axis in the output_grid`(symmetrical_axis, output_grid)\n    return output_grid", "gpt_code": "def find_pixels_with_given_amount(num: int, input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    pixels = []\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] != black:\n                if input_grid.tolist().count(input_grid[i][j]) == num:\n                    pixels.append((i, j))\n    return pixels\ndef change_special_pixel_to_black(special_pixel: Tuple[int, int], output_grid: np.ndarray) -> np.ndarray:\n    i, j = special_pixel\n    output_grid[i][j] = black\n    return output_grid\ndef get_non_black_pixels(input_grid: np.ndarray) -> List[int]:\n    non_black_nums = [0] * 9\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] != black:\n                non_black_nums[input_grid[i][j] - 1] += 1\n    return non_black_nums\ndef stain_black_pixels(symmetrical_axis: int, output_grid: np.ndarray) -> np.ndarray:\n    if symmetrical_axis >= 0:\n        for i in range(output_grid.shape[0]):\n            for j in range(output_grid.shape[1]):\n                if i == symmetrical_axis or i + symmetrical_axis == output_grid.shape[0] - 1:\n                    output_grid[i][j] = black\n    else:\n        for i in range(output_grid.shape[0]):\n            for j in range(output_grid.shape[1]):\n                if j == abs(symmetrical_axis) or j + abs(symmetrical_axis) == output_grid.shape[1] - 1:\n                    output_grid[i][j] = black\n    return output_grid\ndef find_symmetrical_axis(output_grid: np.ndarray) -> int:\n    rows, cols = output_grid.shape\n    for i in range(rows):\n        for j in range(cols):\n            if output_grid[i][j] != black:\n                if i == j:\n                    return i\n                elif i + j == rows - 1:\n                    return -i\n    return 0", "holes": {"find_pixels_with_given_amount": "Find pixels's index whose amount == num in the input_grid", "change_special_pixel_to_black": "change the special_pixel in the output_grid to black", "get_non_black_pixels": "Get the number of every kind of non-black pixles in the input_grid", "stain_black_pixels": "Stain some black pixels according to the symmetry axis in the output_grid", "find_symmetrical_axis": "find the symmetrical_axis of the non-black pixel in the output_grid"}}
{"action": "edit", "code": "def main(input_grid: np.ndarray) -> np.ndarray:\n    non_black_nums = get_non_black_nums(input_grid)\n    min_num = 100\n    for num in non_black_nums:\n        if num != 0 and num < min_num:\n            min_num = num\n    color = non_black_nums.index(min_num) + 1\n    special_pixels = np.where(input_grid == color)\n    output_grid = input_grid.copy()\n    output_grid = change_special_pixel_to_black(special_pixel, output_grid)\n    symmetrical_axis = find_symmetrical_axis(output_grid)\n    output_grid = stain_black_pixels(symmetrical_axis, output_grid)\n    return output_grid\ndef change_special_pixel_to_black(special_pixel: Tuple[np.ndarray, np.ndarray], output_grid: np.ndarray) -> np.ndarray:\n    output_grid[special_pixel] = black\n    return output_grid\ndef stain_black_pixels(symmetrical_axis: int, output_grid: np.ndarray) -> np.ndarray:\n    if symmetrical_axis & 1 << 0:\n        output_grid[:x_center, :] = black\n    if symmetrical_axis & 1 << 1:\n        output_grid[x_center + 1:, :] = black\n    if symmetrical_axis & 1 << 2:\n        output_grid[:, :y_center] = black\n    if symmetrical_axis & 1 << 3:\n        output_grid[:, y_center + 1:] = black\n    return output_grid\ndef find_symmetrical_axis(output_grid: np.ndarray) -> int:\n    non_black_pixels = np.where(output_grid != black)\n    x, y = (non_black_pixels[0], non_black_pixels[1])\n    if len(x) == 0:\n        return -1\n    x_center = int(np.mean(x))\n    y_center = int(np.mean(y))\n    symmetrical_axis = 0\n    for i in range(len(x)):\n        if x[i] == x_center:\n            if y[i] < y_center:\n                symmetrical_axis |= 1 << 0\n            else:\n                symmetrical_axis |= 1 << 1\n        elif y[i] == y_center:\n            if x[i] < x_center:\n                symmetrical_axis |= 1 << 2\n            else:\n                symmetrical_axis |= 1 << 3\n    return symmetrical_axis\ndef get_non_black_nums(input_grid: np.ndarray) -> List[int]:\n    non_b