{"action": "input", "code": "def _hole3(input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    \"\"\"\n    Given an input grid, this function returns the coordinates of all the green pixels.\n    \n    Args:\n    input_grid: A numpy array representing the input grid.\n    \n    Returns:\n    A list of tuples containing the x and y coordinates of the green pixels.\n    \"\"\"\n    green_pixels = []\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] == green:\n                green_pixels.append((i, j))\n    return green_pixels\ndef _hole0(input_grid: np.ndarray, i: int, j: int) -> None:\n    \"\"\"\n    Paints red above, orange on the left, purple on the right and teal below the blue cell at (i, j) in the input grid.\n    \n    Args:\n    input_grid: A numpy array representing the input grid.\n    i: An integer representing the row index of the blue cell.\n    j: An integer representing the column index of the blue cell.\n    \n    Returns:\n    None\n    \"\"\"\n    if i > 0 and input_grid[i - 1][j] != blue:\n        input_grid[i - 1][j] = red\n    if j > 0 and input_grid[i][j - 1] != blue:\n        input_grid[i][j - 1] = orange\n    if j < input_grid.shape[1] - 1 and input_grid[i][j + 1] != blue:\n        input_grid[i][j + 1] = purple\n    if i < input_grid.shape[0] - 1 and input_grid[i + 1][j] != blue:\n        input_grid[i + 1][j] = teal\ndef area_of_square(square: np.ndarray) -> int:\n    \"\"\"\n    Given a square, return the area of the square.\n    \"\"\"\n    return square.shape[0] * square.shape[1]\ndef find_squares(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Find two squares, each filled with a inner suqare in another color. Inverse the color of the outer square and the inner square.\n    If the inner square is 1x1, add 3x1 shape on the four side of the outer square.\n    If the inner square is 2x2, add 2x4 shape on the four side of the outer square.\n    the added shape is the same color as the outer square.\n    \"\"\"\n    output_grid = input_grid.copy()\n    outer_square = _hole0(output_grid)\n    inner_square = _hole1(output_grid)\n    output_grid = _hole2(output_grid, outer_square, inner_square)\n    if _hole3(inner_square) == 1:\n        output_grid = _hole4(output_grid)\n    elif _hole3(inner_square) == 4:\n        output_grid = _hole5(output_grid)\n    return output_grid\ndef fill_four_sides_with_3x1_shape(outer_square: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Given an outer square, fill the four sides of the outer square with a 3x1 shape.\n    \"\"\"\n    outer_color = np.unique(outer_square)[0]\n    shape = np.full((3, 1), outer_color)\n    outer_square = np.concatenate((shape, outer_square, shape), axis=0)\n    outer_square = np.concatenate((shape, outer_square, shape), axis=1)\n    return outer_square\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    find two squares, each filled with a inner suqare in another color. Inverse the color of the outer square and the inner square.\n    If the inner square is 1x1, add 3x1 shape on the four side of the outer square.\n    If the inner square is 2x2, add 2x4 shape on the four side of the outer square.\n    the added shape is the same color as the outer square.\n    \"\"\"\n    output_grid = input_grid.copy()\n    outer_square = find_squares(output_grid)\n    inner_square = find_inner_square(output_grid)\n    output_grid = inverse_colors(output_grid, outer_square, inner_square)\n    if area_of_square(inner_square) == 1:\n        output_grid = fill_four_sides_with_3x1_shape(output_grid)\n    elif area_of_square(inner_square) == 4:\n        output_grid = fill_four_sides_with_4x2_shape(output_grid)\n    return output_grid\ndef _hole5(grid: np.ndarray, square: Tuple[int, int]) -> np.ndarray:\n    \"\"\"\n    Given a grid and a square, this function colors the square red if it is surrounded by grey pixels.\n    \"\"\"\n    i, j = square\n    size = 1\n    while i - size >= 0 and j - size >= 0 and (i + size < grid.shape[0]) and (j + size < grid.shape[1]):\n        if np.all(grid[i - size:i + size + 1, j - size:j + size + 1] == grey):\n            grid[i - size:i + size + 1, j - size:j + size + 1] = red\n            size += 1\n        else:\n            break\n    return grid\ndef find_inner_square(outer_square: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Given an outer square, find the inner square inside it.\n    The inner square is the largest square with a different color than the outer square.\n    \"\"\"\n    colors = np.unique(outer_square)\n    outer_color = colors[0]\n    inner_color = colors[1]\n    if np.sum(outer_square == outer_color) > np.sum(outer_square == inner_color):\n        inner_color, outer_color = (outer_color, inner_color)\n    inner_square = outer_square.copy()\n    while True:\n        mask = np.logical_and(inner_square != inner_color, inner_square != outer_color)\n        if np.sum(mask) == 0:\n            break\n        inner_square[mask] = inner_color\n    return inner_square\ndef inverse_colors(outer_square: np.ndarray, inner_square: np.ndarray) -> Tuple[np.ndarray, np.ndarray]:\n    \"\"\"\n    Given an outer square and an inner square, inverse the color of the outer square and the inner square.\n    \"\"\"\n    outer_color = np.unique(outer_square)[0]\n    inner_color = np.unique(inner_square)[1]\n    outer_square[outer_square == outer_color] = inner_color\n    outer_square[outer_square != inner_color] = outer_color\n    inner_square[inner_square == inner_color] = outer_color\n    inner_square[inner_square != outer_color] = inner_color\n    return (outer_square, inner_square)\ndef fill_four_sides_with_4x2_shape(outer_square: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Given an outer square, fill the four sides of the outer square with a 4x2 shape.\n    \"\"\"\n    outer_color = np.unique(outer_square)[0]\n    shape = np.full((4, 2), outer_color)\n    outer_square = np.concatenate((shape, outer_square