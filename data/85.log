uare: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Given an outer square, fill the four sides of the outer square with a 4x2 shape.\n    \"\"\"\n    outer_color = np.unique(outer_square)[0]\n    shape = np.full((4, 2), outer_color)\n    outer_square = np.concatenate((shape, outer_square, shape), axis=0)\n    outer_square = np.concatenate((shape, outer_square, shape), axis=1)\n    return outer_square", "holes": {"area_of_square": "area of square", "find_squares": "find squares which filled with inner suqares in another color", "fill_four_sides_with_3x1_shape": "fill the four side of outer side with 3x1 shape", "find_inner_square": "find the inner square inside the outer_square", "inverse_colors": "inverse the color of the outer square and the inner suqare", "fill_four_sides_with_4x2_shape": "fill the four side of outer side with 4x2 shape"}}
