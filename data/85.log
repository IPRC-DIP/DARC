{"action": "edit", "code": "def main(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"                                                                                                                                                                 \n    In the black grid, get the two kinds of colors of the squares, inverse the colors.                                                                                  \n    if the square is 3x3, extend the square of 1 grid to outer and draw the four 1x1 corners to black.                                                                  \n    if the square is 4x4, extend the square of 2 grids to outer and draw the four 2x2 corners to black.                                                                 \n    \"\"\"\n    output_grid = input_grid.copy()\n    squares = get_squares(output_grid)\n    for square in squares:\n        outer_color = output_grid[square[0]][square[1]]\n        inner_color = output_grid[square[0] + 1][square[1] + 1]\n        output_grid = inverse_color(output_grid, outer_color, inner_color)\n        output_grid = extend_shape(output_grid)\n    return output_grid\ndef extend_shape(grid: np.ndarray, square_size: int, color: int) -> np.ndarray:\n    \"\"\"\n    Given a grid, a square size, and a color, extend the square of the given size to the outer edges of the grid.\n    Draw the four corners of the extended square with the given color.\n    \"\"\"\n    extended_grid = grid.copy()\n    for i in range(square_size):\n        for j in range(square_size):\n            extended_grid[0 + i][0 + j] = color\n            extended_grid[0 + i][-1 - j] = color\n            extended_grid[-1 - i][0 + j] = color\n            extended_grid[-1 - i][-1 - j] = color\n    return extended_grid\ndef inverse_color(grid: np.ndarray, color: int) -> np.ndarray:\n    \"\"\"\n    Given a grid and a color, return a new grid with the color inverted.\n    \"\"\"\n    return np.where(grid == color, 0, color)\ndef get_squares(input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    \"\"\"                                                                                                                                                                 \n    Given an input grid, return a list of tuples representing the top-left corner of each square in the grid. \n    \"\"\"\n    squares = []\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if i + 2 < input_grid.shape[0] and j + 2 < input_grid.shape[1]:\n                squares.append((i, j))\n    return squares", "user_code": "def main(input_grid: np.ndarray) -> np.ndarray:                                                                                                                         \n    \"\"\"                                                                                                                                                                 \n    In the black grid, get the two kinds of colors of the squares, inverse the colors.                                                                                  \n    if the square is 3x3, extend the square of 1 grid to outer and draw the four 1x1 corners to black.                                                                  \n    if the square is 4x4, extend the square of 2 grids to outer and draw the four 2x2 corners to black.                                                                 \n    \"\"\"                                                                                                                                                                 \n    output_grid = input_grid.copy()                                                                                                                                     \n    squares = `get_squares`(output_grid)                                                                                                                                  \n    for square in squares:\n        outer_color = output_grid[square[0]][square[1]]\n        inner_color = output_grid[square[0]+1][square[1]+1]                                                                              \n        output_grid = `inverse color`(output_grid, outer_color, inner_color)\n        output_grid = `extend_shape`(output_grid)\n    return output_grid ", "gpt_code": "def extend_shape(grid: np.ndarray, square_size: int, color: int) -> np.ndarray:\n    \"\"\"\n    Given a grid, a square size, and a color, extend the square of the given size to the outer edges of the grid.\n    Draw the four corners of the extended square with the given color.\n    \"\"\"\n    extended_grid = grid.copy()\n    for i in range(square_size):\n        for j in range(square_size):\n            extended_grid[0 + i][0 + j] = color\n            extended_grid[0 + i][-1 - j] = color\n            extended_grid[-1 - i][0 + j] = color\n            extended_grid[-1 - i][-1 - j] = color\n    return extended_grid\ndef inverse_color(grid: np.ndarray, color: int) -> np.ndarray:\n    \"\"\"\n    Given a grid and a color, return a new grid with the color inverted.\n    \"\"\"\n    return np.where(grid == color, 0, color)\ndef get_squares(input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    \"\"\"                                                                                                                                                                 \n    Given an input grid, return a list of tuples representing the top-left corner of each square in the grid. \n    \"\"\"\n    squares = []\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if i + 2 < input_grid.shape[0] and j + 2 < input_grid.shape[1]:\n                squares.append((i, j))\n    return squares", "holes": {"extend_shape": "extend_shape", "inverse_color": "inverse color", "get_squares": "get_squares"}}
