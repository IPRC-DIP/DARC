{"action": "edit", "code": "def find_unique_color(input: np.ndarray) -> int:\n    \"\"\"\n    Args:\n    input: A 2-dim numpy array representing the input pattern.\n\n    Returns:\n    An integer representing the unique color in the input pattern.\n    \"\"\"\n    unique, counts = np.unique(input, return_counts=True)\n    unique_color = unique[np.where(counts == 1)][0]\n    return unique_color\ndef main(input):\n    color = find_unique_color(input)\n    output = copy_pattern_with_unique_color(input, color)\n    return output\ndef copy_pattern_with_unique_color(input: np.ndarray, color: int) -> np.ndarray:\n    \"\"\"\n    Args:\n    input: A 2-dim numpy array representing the input pattern.\n    color: An integer representing the unique color in the input pattern.\n\n    Returns:\n    A 2-dim numpy array representing the output pattern with the unique color repeated according to the direction of the position which is color.\n    \"\"\"\n    output = np.zeros_like(input)\n    for i in range(input.shape[0]):\n        for j in range(input.shape[1]):\n            if input[i][j] == color:\n                if i > 0 and input[i - 1][j] != color:\n                    output[i - 1][j] = color\n                if i < input.shape[0] - 1 and input[i + 1][j] != color:\n                    output[i + 1][j] = color\n                if j > 0 and input[i][j - 1] != color:\n                    output[i][j - 1] = color\n                if j < input.shape[1] - 1 and input[i][j + 1] != color:\n                    output[i][j + 1] = color\n    return output", "user_code": "", "gpt_code": "def find_unique_color(input: np.ndarray) -> int:\n    \"\"\"\n    Args:\n    input: A 2-dim numpy array representing the input pattern.\n\n    Returns:\n    An integer representing the unique color in the input pattern.\n    \"\"\"\n    unique, counts = np.unique(input, return_counts=True)\n    unique_color = unique[np.where(counts == 1)][0]\n    return unique_color\ndef main(input):\n    color = find_unique_color(input)\n    output = copy_pattern_with_unique_color(input, color)\n    return output\ndef copy_pattern_with_unique_color(input: np.ndarray, color: int) -> np.ndarray:\n    \"\"\"\n    Args:\n    input: A 2-dim numpy array representing the input pattern.\n    color: An integer representing the unique color in the input pattern.\n\n    Returns:\n    A 2-dim numpy array representing the output pattern with the unique color repeated according to the direction of the position which is color.\n    \"\"\"\n    output = np.zeros_like(input)\n    for i in range(input.shape[0]):\n        for j in range(input.shape[1]):\n            if input[i][j] == color:\n                if i > 0 and input[i - 1][j] != color:\n                    output[i - 1][j] = color\n                if i < input.shape[0] - 1 and input[i + 1][j] != color:\n                    output[i + 1][j] = color\n                if j > 0 and input[i][j - 1] != color:\n                    output[i][j - 1] = color\n                if j < input.shape[1] - 1 and input[i][j + 1] != color:\n                    output[i][j + 1] = color\n    return output", "holes": {"main": ""}}
