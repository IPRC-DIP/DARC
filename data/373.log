{"action": "input", "code": "def find_mid_length_grey_line(input_grid: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    Finds the mid length grey line in the input grid and returns its starting and ending coordinates.\n    \"\"\"\n    mid_length = 0\n    start_coord = (0, 0)\n    end_coord = (0, 0)\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] == grey:\n                length = 1\n                for k in range(j + 1, input_grid.shape[1]):\n                    if input_grid[i][k] == grey:\n                        length += 1\n                    else:\n                        break\n                if length > mid_length and length < find_longest_grey_line(input_grid)[1][1]:\n                    mid_length = length\n                    start_coord = (i, j)\n                    end_coord = (i, j + length - 1)\n                length = 1\n                for k in range(i + 1, input_grid.shape[0]):\n                    if input_grid[k][j] == grey:\n                        length += 1\n                    else:\n                        break\n                if length > mid_length and length < find_longest_grey_line(input_grid)[1][1]:\n                    mid_length = length\n                    start_coord = (i, j)\n                    end_coord = (i + length - 1, j)\n    return (start_coord, end_coord)\ndef find_shortest_grey_line(input_grid: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    Finds the shortest grey line in the input grid and returns its starting and ending coordinates.\n    \"\"\"\n    min_length = float('inf')\n    start_coord = (0, 0)\n    end_coord = (0, 0)\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] == grey:\n                length = 1\n                for k in range(j + 1, input_grid.shape[1]):\n                    if input_grid[i][k] == grey:\n                        length += 1\n                 