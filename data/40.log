{"action": "edit", "code": "def color_diagonal_line(input_grid: np.ndarray, grid: Tuple[int, int]) -> np.ndarray:\n    \"\"\"\n    Starting at the given grid position, colors all black grids on the diagonal line going right with the same color as the diagonal line grid,\n    stops when reaching a colored grid, and returns the modified input grid.\n\n    Args:\n    - input_grid (np.ndarray): a 2D numpy array representing a grid of colored squares\n    - grid (Tuple[int, int]): a tuple representing the position of the starting grid\n\n    Returns:\n    - np.ndarray: a 2D numpy array representing the modified grid with the diagonal line colored\n    \"\"\"\n    i, j = grid\n    color = input_grid[i][j]\n    while i >= 0 and j < input_grid.shape[1] and (input_grid[i][j] == black):\n        input_grid[i][j] = color\n        i -= 1\n        j += 1\n    return input_grid\ndef find_colored_rectangles(input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    \"\"\"\n    Given a 2D numpy array representing a grid of colored squares, this function finds all colored rectangles of 4 squares\n    and returns their left-top corner positions as a list of tuples.\n\n    Args:\n    - input_grid (np.ndarray): a 2D numpy array representing a grid of colored squares\n\n    Returns:\n    - List[Tuple[int, int]]: a list of tuples representing the left-top corner positions of all colored rectangles of 4 squares\n    \"\"\"\n    rect_positions = []\n    for i in range(input_grid.shape[0] - 1):\n        for j in range(input_grid.shape[1] - 1):\n            if input_grid[i][j] == input_grid[i + 1][j] == input_grid[i][j + 1] == input_grid[i + 1][j + 1]:\n                rect_positions.append((i, j))\n    return rect_positions\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    rect_positions = find_colored_rectangles(input_grid)\n    for rect in rect_positions:\n        line_top = find_last_colored_grid(input_grid, rect)\n        diagonal_line = find_diagonal_line(input_grid, rect, line_top)\n        for grid in diagonal_line:\n            input_grid = color_diagonal_line(input_grid, grid)\n    return input_grid\ndef find_diagonal_line(input_grid: np.ndarray, rect: Tuple[int, int], line_top: Tuple[int, int]) -> List[Tuple[int, int]]:\n    \"\"\"\n    Given a 2D numpy array representing a grid of colored squares, the left-top corner position of a colored rectangle of 4 squares,\n    and the position of the last colored grid on the diagonal line from the rectangle to the top of the grid, this function finds\n    all positions of the grids on the diagonal line and returns them as a list of tuples.\n\n    Args:\n    - input_grid (np.ndarray): a 2D numpy array representing a grid of colored squares\n    - rect (Tuple[int, int]): a tuple representing the left-top corner position of a colored rectangle of 4 squares\n    - line_top (Tuple[int, int]): a tuple representing the position of the last colored grid on the diagonal line from the rectangle to the top of the grid\n\n    Returns:\n    - List[Tuple[int, int]]: a list of tuples representing the positions of all grids on the diagonal line\n    \"\"\"\n    i, j = rect\n    i_top, j_top = line_top\n    diagonal_line = []\n    while i <= i_top and j <= j_top:\n        diagonal_line.append((i, j))\n        i += 1\n        j += 1\n    return diagonal_line\ndef find_last_colored_grid(input_grid: np.ndarray, rect: Tuple[int, int]) -> Tuple[int, int]:\n    \"\"\"\n    Goes diagonally left up from the input rect position, stops until the grid is black. Returns the position of the last colored grid.\n\n    Args:\n    - input_grid (np.ndarray): a 2D numpy array representing a grid of colored squares\n    - rect (Tuple[int, int]): a tuple representing the left-top corner position of a colored rectangle of 4 squares\n\n    Returns:\n    - Tuple[int, int]: a tuple representing the position of the last colored grid\n    \"\"\"\n    i, j = rect\n    while i >= 0 and j >= 0 and (input_grid[i][j] != black):\n        i -= 1\n   