w, axis=1)][:, ~np.all(input == yellow, axis=0)]", "holes": {"count_yellow_in_first_column": "count the yellow positions in the first column", "count_yellow_in_first_row": "count the yellow positions in the first row", "separate_input_into_parts": "separate the input into x*y parts", "find_different_color": "find the one which has different colors", "repeat_pattern_and_add_dividing_lines": "repeat the pattern in a * b, and add yellow dividing lines", "remove_yellow_rows_and_columns": "remove all yellow rows and columns"}}
