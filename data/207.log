{"action": "edit", "code": "def find_rectangle(input_grid: np.ndarray, c: int) -> np.ndarray:\n    \"\"\"\n    This function takes an input grid and a color c and returns a rectangle with the boundary color c in the input grid.\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    c: An integer representing the color of the boundary of the rectangle\n    \n    Returns:\n    A numpy array representing the rectangle with the boundary color c in the input grid\n    \"\"\"\n    indices = np.argwhere(input_grid == c)\n    min_row = np.min(indices[:, 0])\n    max_row = np.max(indices[:, 0])\n    min_col = np.min(indices[:, 1])\n    max_col = np.max(indices[:, 1])\n    rectangle = input_grid[min_row:max_row + 1, min_col:max_col + 1]\n    return rectangle\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    c = get_fourth_highest_color(input_grid)\n    m = find_rectangle(input_grid, c)\n    h, w = get_non_boundary_dimensions(m)\n    out = find_black_matrix(input_grid, h, w, c)\n    return out\ndef find_black_matrix(input_grid: np.ndarray, h: int, w: int, c: int) -> np.ndarray:\n    \"\"\"\n    This function takes an input grid, height h, width w, and color c and returns a matrix full of black pixels with the height h and the width w, \n    which has its boundary color replaced with c in the input grid.\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    h: An integer representing the height of the black matrix\n    w: An integer representing the width of the black matrix\n    c: An integer representing the color of the boundary of the black matrix\n    \n    Returns:\n    A numpy array representing the black matrix with the boundary color c in the input grid\n    \"\"\"\n    black_matrix = np.zeros((h, w), dtype=int)\n    black_matrix[0, :] = c\n    black_matrix[h - 1, :] = c\n    black_matrix[:, 0] = c\n    black_matrix[:, w - 1] = c\n    return black_matrix\ndef get_fourth_highest_color(input_grid: np.ndarray) -> int:\n    \"\"\"\n    This function takes an input grid and returns the color with the fourth highest number of pixels in the grid.\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    \n    Returns:\n    An integer representing the color with the fourth highest number of pixels in the input grid\n    \"\"\"\n    color_counts = np.bincount(input_grid.flatten())\n    sorted_colors = np.argsort(color_counts)[::-1]\n    fourth_highest_color = sorted_colors[3]\n    return fourth_highest_color\ndef get_non_boundary_dimensions(m: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    This function takes a numpy array m and returns the height and width of the non-boundary part of m.\n    \n    Args:\n    m: A numpy array representing the input grid\n    \n    Returns:\n    A tuple of integers representing the height and width of the non-boundary part of m\n    \"\"\"\n    h, w = m.shape\n    non_boundary_m = m[1:h - 1, 1:w - 1]\n    h, w = non_boundary_m.shape\n    return (h, w)", "user_code": "def main(input_grid: np.ndarray) -> np.ndarray:\n c = `Return the color with the forth highest number of pixels in the input grid`(input_grid)\n m = `Find and return a rectangle with the boundary color c in the input grid`(input_grid, c)\n h, w = `Return the height and width of non-boundary part of m`(m)\n out = `Find a matrix full of black pixels in the input grid, which has the height h and the width w, replace its boundary color with c`(input_grid, h, w, c)\n return out\n\n", "gpt_code": "def find_rectangle(input_grid: np.ndarray, c: int) -> np.ndarray:\n    \"\"\"\n    This function takes an input grid and a color c and returns a rectangle with the boundary color c in the input grid.\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    c: An integer representing the color of the boundary of the rectangle\n    \n    Returns:\n    A numpy array representing the rectangle with the boundary color c in the input grid\n    \"\"\"\n    indices = np.argwhere(input_grid == c)\n    min_row = np.min(indices[:, 0])\n    max_row = np.max(indices[:, 0])\n    min_col = np.min(indices[:, 1])\n    max_col = np.max(indices[:, 1])\n    rectangle = input_grid[min_row:max_row + 1, min_col:max_col + 1]\n    return rectangle\ndef find_black_matrix(input_grid: np.ndarray, h: int, w: int, c: int) -> np.ndarray:\n    \"\"\"\n    This function takes an input grid, height h, width w, and color c and returns a matrix full of black pixels with the height h and the width w, \n    which has its boundary color replaced with c in the input grid.\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    h: An integer representing the height of the black matrix\n    w: An integer representing the width of the black matrix\n    c: An integer representing the color of the boundary of the black matrix\n    \n    Returns:\n    A numpy array representing the black matrix with the boundary color c in the input grid\n    \"\"\"\n    black_matrix = np.zeros((h, w), dtype=int)\n    black_matrix[0, :] = c\n    black_matrix[h - 1, :] = c\n    black_matrix[:, 0] = c\n    black_matrix[:, w - 1] = c\n    return black_matrix\ndef get_fourth_highest_color(input_grid: np.ndarray) -> int:\n    \"\"\"\n    This function takes an input grid and returns the color with the fourth highest number of pixels in the grid.\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    \n    Returns:\n    An integer representing the color with the fourth highest number of pixels in the input grid\n    \"\"\"\n    color_counts = np.bincount(input_grid.flatten())\n    sorted_colors = np.argsort(color_counts)[::-1]\n    fourth_highest_color = sorted_colors[3]\n    return fourth_highest_color\ndef get_non_boundary_dimensions(m: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    This function takes a numpy array m and returns the height and width of the non-boundary part of m.\n    \n    Args:\n    m: A numpy array representing the input grid\n    \n    Returns:\n    A tuple of integers representing the height and width of the non-boundary part of m\n    \"\"\"\n    h, w = m.shape\n    non_boundary_m = m[1:h - 1, 1:w - 1]\n    h, w = non_boundary_m.shape\n    return (h, w)", "holes": {"find_rectangle": "Find and return a rectangle with the boundary color c in the input grid", "find_black_matrix": "Find a matrix full of black pixels in the input grid, which has the height h and the width w, replace its boundary color with c", "get_fourth_highest_color": "Return the color with the forth highest number of pixels in the input grid", "get_non_boundary_dimensions": "Return the height and width of non-boundary part of m"}}
