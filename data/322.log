{"action": "input", "code": "def is_within_boundary(input_grid: np.ndarray, current_point: Tuple[int, int]) -> bool:\n    \"\"\"\n    Given a 2D numpy array and a point, check if the point is within the boundary of the array.\n    \n    Args:\n    input_grid: A 2D numpy array\n    current_point: A tuple containing the row and column indices of a point\n    \n    Returns:\n    A boolean value indicating whether the point is within the boundary of the input_grid.\n    \"\"\"\n    rows, cols = input_grid.shape\n    row, col = current_point\n    return 0 <= row < rows and 0 <= col < cols\ndef move_up_two_points(current_point: Tuple[int, int]) -> Tuple[int, int]:\n    \"\"\"\n    Given a tuple containing the row and column indices of a point, move the point up two points.\n    \n    Args:\n    current_point: A tuple containing the row and column indices of a point\n    \n    Returns:\n    A tuple containing the row and column indices of the point moved up two points.\n    \"\"\"\n    row, col = current_point\n    return (row - 2, col)\ndef move_down_two_points(current_point: Tuple[int, int]) -> Tuple[int, int]:\n    \"\"\"\n    Given a tuple containing the row and column indices of a point, move the point down two points.\n    \n    Args:\n    current_point: A tuple containing the row and column indices of a point\n    \n    Returns:\n    A tuple containing the row and column indices of the point moved down two points.\n    \"\"\"\n    row, col = current_point\n    return (row + 2, col)\ndef find_teal_point(input_grid: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    Given a 2D numpy array, find the coordinates of the first occurrence of the value \"teal\".\n    \n    Args:\n    input_grid: A 2D numpy array\n    \n    Returns:\n    A tuple containing the row and column indices of the first occurrence of \"teal\" in the input_grid.\n    \"\"\"\n    teal_indices = np.where(input_grid == teal)\n    return (teal_indices[0][0], teal_indices[1][0])\ndef draw_right_adjacent_points_to_grey(input_grid: np.ndarray, current_point: Tuple[int, int]) -> np.ndarray:\n    \"\"\"\n    Given a 2D numpy array and a point, draw its two right adjacent points to grey.\n    \n    Args:\n    input_grid: A 2D numpy array\n    current_point: A tuple containing the row and column indices of a point\n    \n    Returns:\n    A 2D numpy array with the two right adjacent points of the current_point drawn to grey.\n    \"\"\"\n    row, col = current_point\n    if col < input_grid.shape[1] - 1:\n        input_grid[row][col + 1] = grey\n    if col < input_grid.shape[1] - 2:\n        input_grid[row][col + 2] = grey\n    return input_grid\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    teal_point = find_teal_point(input_grid)\n    current_point = teal_point\n    while is_within_boundary(input_grid, current_point):\n        input_grid = draw_upper_adjacent_points_to_grey(input_grid, current_point)\n        current_point = move_up_two_points(current_point)\n        input_grid = draw_right_adjacent_points_to_grey(input_grid, current_point)\n        current_point = move_right_two_points(current_point)\n    current_point = teal_point\n    while is_within_boundary(input_grid, current_point):\n        input_grid = draw_lower_adjacent_points_to_grey(input_grid, current_point)\n        current_point = move_down_two_points(current_point)\n        input_grid = draw_left_adjacent_points_to_grey(input_grid, current_point)\n        current_point = move_left_two_points(current_point)\ndef move_right_two_points(current_point: Tuple[int, int]) -> Tuple[int, int]:\n    \"\"\"\n    Given a tuple containing the row and column indices of a point, move the point right two points.\n    \n    Args:\n    current_point: A tuple containing the row and column indices of a point\n    \n    Returns:\n    A tuple containing the row and column indices of the point moved right two points.\n    \"\"\"\n    row, col = current_point\n    return (row, col + 2)\ndef move_left_two_points(current_point: Tuple[int, int]) -> Tuple[int, int]:\n    \"\"\"\n    Given a tuple containing the row and column indices of a point, move the point left two points.\n    \n    Args:\n    current_point: A tuple containing the row and column indices of a point\n    \n    Returns:\n    A tuple containing the row and column indices of the point moved left two points.\n    \"\"\"\n    row, col = current_point\n    return (row, col - 2)\ndef draw_left_adjacent_points_to_grey(input_grid: np.ndarray, current_point: Tuple[int, int]) -> np.ndarray:\n    \"\"\"\n    Given a 2D numpy array and a point, draw its two left adjacent points to grey.\n    \n    Args:\n    input_grid: A 2D numpy array\n    current_point: A tuple containing the row and column indices of a point\n    \n    Returns:\n    A 2D numpy array with the two left adjacent points of the current_point drawn to grey.\n    \"\"\"\n    row, col = current_point\n    if col > 1:\n        input_grid[row][col - 1] = grey\n        input_grid[row][col - 2] = grey\n    elif col == 1:\n        input_grid[row][col - 1] = grey\n    return input_grid\ndef draw_upper_adjacent_points_to_grey(input_grid: np.ndarray, current_point: Tuple[int, int]) -> np.ndarray:\n    \"\"\"\n    Given a 2D numpy array and a point, draw its two upper adjacent points to grey.\n    \n    Args:\n    input_grid: A 2D numpy array\n    current_point: A tuple containing the row and column indices of a point\n    \n    Returns:\n    A 2D numpy array with the two upper adjacent points of the current_point drawn to grey.\n    \"\"\"\n    row, col = current_point\n    if row > 0:\n        if col > 0:\n            input_grid[row - 1][col - 1] = grey\n        if col < input_grid.shape[1] - 1:\n            input_grid[row - 1][col + 1] = grey\n    return input_grid\ndef draw_lower_adjacent_points_to_grey(input_grid: np.ndarray, current_point: Tuple[int, int]) -> np.ndarray:\n    \"\"\"\n    Given a 2D numpy array and a point, draw its two lower adjacent points to grey.\n   