{"action": "input", "code": "def extend_green_pixel(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Extend the green pixel to the right until it meets a non-black pixel\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    \n    Returns:\n    A numpy array representing the output grid with the green pixel extended to the right\n    \"\"\"\n    output_grid = np.copy(input_grid)\n    for i in range(output_grid.shape[0]):\n        for j in range(output_grid.shape[1]):\n            if output_grid[i][j] == green:\n                k = j + 1\n                while k < output_grid.shape[1] and output_grid[i][k] == black:\n                    k += 1\n                output_grid[i][j:k] = green\n    return output_grid\ndef extend_green_pixel_left(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Extend the most up green pixel to the left until it meets a non-black pixel\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    \n    Returns:\n    A numpy array representing the output grid with the most up green pixel extended to the left\n    \"\"\"\n    output_grid = np.copy(input_grid)\n    for i in range(output_grid.shape[0]):\n        for j in range(output_grid.shape[1]):\n            if output_grid[i][j] == green:\n                k = i - 1\n                while k >= 0 and output_grid[k][j] == black:\n                    k -= 1\n                output_grid[k + 1:i + 1, j] = green\n    return output_grid\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    output_grid = extend_green_pixel(input_grid)\n    output_grid = extend_green_pixel_up(output_grid)\n    output_grid = extend_green_pixel_left(output_grid)\n    return output_grid\ndef extend_green_pixel_up(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Extend the most right green pixel to the up until it meets a non-black pixel\n    \n    Args:\n    input_grid: A numpy array representing the input grid\n    \n    Returns:\n    A numpy array repre