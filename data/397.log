{"action": "edit", "code": "def fill_column(output_grid: np.ndarray, fill_colors: np.ndarray, i: int) -> np.ndarray:\n    color_nums = get_num_colors(fill_colors)\n    column = np.zeros([output_grid.shape[0], 1])\n    for j in range(color_nums):\n        indices = np.where(fill_colors == j)\n        if len(indices[0]) > 0:\n            row_min = np.min(indices[0])\n            row_max = np.max(indices[0])\n            column_min = np.min(indices[1])\n            column_max = np.max(indices[1])\n            row_center = (row_min + row_max) // 2\n            column_center = (column_min + column_max) // 2\n            row_offset = output_grid.shape[0] - 1 - i\n            row_pos = row_offset + 5 * (j - 1) + (2 - row_center)\n            column_pos = 5 * (j - 1) + (2 - column_center)\n            if row_pos >= 0 and row_pos < output_grid.shape[0] and (column_pos >= 0) and (column_pos < output_grid.shape[1]):\n                column[row_pos, column_pos] = j\n    return np.concatenate((output_grid[:, :i], column, output_grid[:, i + 1:]), axis=1)\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    color_nums = get_num_colors(input_grid)\n    output_grid = np.zeros([5 * (color_nums - 1), 5 * (color_nums - 1)])\n    fill_colors = input_grid.copy()\n    output_grid[-1] = np.concatenate(fill_colors, np.zeros([5 * (color_nums - 2)]))\n    for i in reversed(range(0, output_grid.shape[0] - 1)):\n        fill_colors = pad_fill_colors(fill_colors)\n        output_grid = fill_column(output_grid)\n    return output_grid\ndef pad_fill_colors(fill_colors: np.ndarray, output_shape: Tuple[int, int]) -> np.ndarray:\n    if fill_colors.shape[0] <= output_shape[0]:\n        return np.concatenate((np.zeros((1, fill_colors.shape[1])), fill_colors))\n    else:\n        return np.concatenate((np.zeros((1, fill_colors.shape[1])), fill_colors[:, :-1]))\ndef get_num_colors(input_colors: np.ndarray) -> int:\n    return len(np.unique(input_colors))", "user_code": "def main(input_grid:np.ndarray) 