grid: np.ndarray) -> np.ndarray:\n    output_grid[:, 3:] = input_grid\n    return output_grid", "holes": {"flip_left_to_right": "Flip input_grid leftside right", "assign_input_to_left_half": "Assign input_grid to the left half of output_grid", "create_image_matrix": "Create a 3x6 image matrix", "assign_input_to_right_half": "Assign input_grid to the right half of output_grid"}}
