{"action": "edit", "code": "def move_to_edge(p: Tuple[int, int], record: Tuple[int, int], input_grid: np.ndarray) -> np.ndarray:\n    color = input_grid[p[0]][p[1]]\n    if record[0] == p[0]:\n        if record[1] < p[1]:\n            for j in range(p[1], input_grid.shape[1]):\n                if input_grid[p[0]][j] != color:\n                    break\n                input_grid[p[0]][j] = black\n            return input_grid\n        else:\n            for j in range(p[1], -1, -1):\n                if input_grid[p[0]][j] != color:\n                    break\n                input_grid[p[0]][j] = black\n            return input_grid\n    elif record[0] < p[0]:\n        for i in range(p[0], input_grid.shape[0]):\n            if input_grid[i][p[1]] != color:\n                break\n            input_grid[i][p[1]] = black\n        return input_grid\n    else:\n        for i in range(p[0], -1, -1):\n            if input_grid[i][p[1]] != color:\n                break\n            input_grid[i][p[1]] = black\n        return input_grid\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    for p in get_non_black_inner_pixels(input_grid):\n        record = find_same_color_edge(p, input_grid)\n        input_grid = move_to_edge(p, record, input_grid)\n    return input_grid\ndef get_non_black_inner_pixels(input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    non_black_pixels = []\n    for i in range(1, input_grid.shape[0] - 1):\n        for j in range(1, input_grid.shape[1] - 1):\n            if input_grid[i][j] != black:\n                non_black_pixels.append((i, j))\n    return non_black_pixels\ndef find_same_color_edge(p: Tuple[int, int], input_grid: np.ndarray) -> Tuple[int, int]:\n    color = input_grid[p[0]][p[1]]\n    if input_grid[p[0] - 1][p[1]] == color and input_grid[p[0] + 1][p[1]] == color:\n        return (p[0], p[1] - 1) if input_grid[p[0]][p[1] - 1] == color else (p[0], p[1] + 1)\n    elif input_grid[p[0]][p[1] - 1] == color and input_grid[p[0]][p[1] + 1] == color:\n        return (p[0] - 1, p[1]) if input_grid[p[0] - 1][p[1]] == color else (p[0] + 1, p[1])\n    else:\n        return None", "user_code": "def main(input_grid: np.ndarray) -> np.ndarray:\n    for p in `all not black inner pixels`(input_grid):\n        record = `find which edge line without corner has the same color with p`(p, input_grid)\n        input_grid = `according to record, move p to the edge line until touch the line, donnot change the pixel in moving trace.`(p, record, input_grid)\n    return input_grid\n", "gpt_code": "def move_to_edge(p: Tuple[int, int], record: Tuple[int, int], input_grid: np.ndarray) -> np.ndarray:\n    color = input_grid[p[0]][p[1]]\n    if record[0] == p[0]:\n        if record[1] < p[1]:\n            for j in range(p[1], input_grid.shape[1]):\n                if input_grid[p[0]][j] != color:\n                    break\n                input_grid[p[0]][j] = black\n            return input_grid\n        else:\n            for j in range(p[1], -1, -1):\n                if input_grid[p[0]][j] != color:\n                    break\n                input_grid[p[0]][j] = black\n            return input_grid\n    elif record[0] < p[0]:\n        for i in range(p[0], input_grid.shape[0]):\n            if input_grid[i][p[1]] != color:\n                break\n            input_grid[i][p[1]] = black\n        return input_grid\n    else:\n        for i in range(p[0], -1, -1):\n            if input_grid[i][p[1]] != color:\n                break\n            input_grid[i][p[1]] = black\n        return input_grid\ndef get_non_black_inner_pixels(input_grid: np.ndarray) -> List[Tuple[int, int]]:\n    non_black_pixels = []\n    for i in range(1, input_grid.shape[0] - 1):\n        for j in range(1, input_grid.shape[1] - 1):\n            if input_grid[i][j] != black:\n                non_black_pixels.append((i, j))\n    return non_black_pixels\ndef find_same_color_edge(p: Tuple[int, int], input_grid: np.ndarray) -> Tuple[int, int]:\n    color = i