{"action": "input", "code": "def replace_black_with_blue_below_maroon(input_grid: np.ndarray) -> np.ndarray:\n    out = np.copy(input_grid)\n    w = out.shape[1]\n    for j in range(w):\n        flag = False\n        for i in range(out.shape[0]):\n            if out[i][j] == maroon:\n                flag = True\n            elif flag and out[i][j] == black:\n                out[i][j] = blue\n    return out\ndef has_maroon_without_green(grid: np.ndarray, col: int) -> bool:\n    has_maroon = False\n    has_green = False\n    for i in range(grid.shape[0]):\n        if grid[i][col] == maroon:\n            has_maroon = True\n        elif grid[i][col] == green:\n            has_green = True\n    return has_maroon and (not has_green)\ndef get_width(grid: np.ndarray) -> int:\n    return grid.shape[1]\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    out = replace_black_with_blue_below_maroon(input_grid)\n    w = get_width(out)\n    for i in range(4):\n        for j in range(w):\n            flag = has_maroon_without_green(out, j)\n            if flag:\n                r1, r2 = get_min_max_rows_of_maroon(out, j)\n                gap = (r2 - r1) // 2\n                out = replace_pixels_with_green(out, r1, r2, c1, c2, gap)\n    return out\ndef get_min_max_rows_of_maroon(grid: np.ndarray, col: int) -> Tuple[int, int]:\n    min_row = -1\n    max_row = -1\n    for i in range(grid.shape[0]):\n        if grid[i][col] == maroon:\n            if min_row == -1:\n                min_row = i\n            max_row = i\n    return (min_row, max_row)\ndef replace_pixels_with_green(matrix: np.ndarray, r1: int, r2: int, j: int, gap: int) -> np.ndarray:\n    c1 = j - gap\n    c2 = j + gap + r2 - r1\n    for i in range(r1 - gap, r2 + gap + 1):\n        for j in range(c1, c2 + 1):\n            if matrix[i][j] == black or matrix[i][j] == blue:\n                matrix[i][j] = green\n    return matrix", "user_code": "def main(input_grid: np.ndarray) -> np.ndarray:\n  out = `For each column, i