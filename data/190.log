mpy array representing a grid of colored blocks, deletes rows and columns that do not contain blue blocks.\n    \n    Args:\n    - grid: a 2D numpy array of integers representing the color of each block\n    \n    Returns:\n    - A 2D numpy array representing the grid with rows and columns that do not contain blue blocks removed.\n    \"\"\"\n    blue_indices = np.argwhere(grid == blue)\n    min_row, max_row = (blue_indices[:, 0].min(), blue_indices[:, 0].max())\n    min_col, max_col = (blue_indices[:, 1].min(), blue_indices[:, 1].max())\n    return grid[min_row:max_row + 1, min_col:max_col + 1]", "holes": {"find_yellow_pattern": "Find several yellow blocks that have the same positional relationship with the yellow blocks in the blue area and enclose them in the same way in pattern.", "delete_rows_cols_without_blue": "Delete rows and columns that do not contain blue."}}
