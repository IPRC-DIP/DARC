{"action": "input", "code": "def find_color_sets(input_grid: np.ndarray) -> Tuple[Set[int], Set[int]]:\n    \"\"\"\n    Given an input grid, this function finds the two non-black colors in the grid and returns them as two sets.\n    Args:\n    - input_grid: A numpy array representing the input grid.\n    Returns:\n    - A tuple of two sets, where each set contains the indices of the cells in the input grid that have one of the two non-black colors.\n    \"\"\"\n    non_black_indices, = np.where(input_grid != black)\n    set1 = set(non_black_indices[input_grid[non_black_indices[0]] == input_grid[non_black_indices[0]][0]])\n    set2 = set(non_black_indices[input_grid[non_black_indices[0]] != input_grid[non_black_indices[0]][0]])\n    return (set1, set2)\ndef color_black_points_left_right(input_grid: np.ndarray, small_set_up: int, small_set_down: int, left: int, right: int, small_set: Set[int], large_set: Set[int]) -> np.ndarray:\n    \"\"\"\n    Color all black points in area [left:right,small_set_up+1:small_set_down-1] teal.\n    Args:\n    - input_grid: A numpy array representing the input grid.\n    - small_set_up: An integer representing the y coordinate of the upper bound of the smaller set.\n    - small_set_down: An integer representing the y coordinate of the lower bound of the smaller set.\n    - left: An integer representing the x coordinate of the left bound of the area to color.\n    - right: An integer representing the x coordinate of the right bound of the area to color.\n    - small_set: A set of indices representing cells with one of the two non-black colors.\n    - large_set: A set of indices representing cells with one of the two non-black colors.\n    Returns:\n    - A numpy array representing the output grid with the specified area colored teal.\n    \"\"\"\n    for i in range(left, right):\n        for j in range(small_set_up + 1, small_set_down - 1):\n            if input_grid[j * 5 + i] == black:\n                input_grid[j * 5 + i] = teal\n    return input_grid\ndef get_new_y_coordinate(small_set_center: Tuple[int, int], large_set_center: Tuple[int, int]) -> Tuple[int, int]:\n    \"\"\"\n    Given two tuples of integers representing the x and y coordinates of the centers of two sets, this function returns a new tuple of integers representing the x and y coordinates of a point that is vertically aligned with the centers of the two sets, with the y coordinate of the smaller set's center coming first.\n    Args:\n    - small_set_center: A tuple of two integers representing the x and y coordinates of the center of the smaller set.\n    - large_set_center: A tuple of two integers representing the x and y coordinates of the center of the larger set.\n    Returns:\n    - A tuple of two integers representing the x and y coordinates of a point that is vertically aligned with the centers of the two sets, with the y coordinate of the smaller set's center coming first.\n    \"\"\"\n    if small_set_center[1] < large_set_center[1]:\n        return ((small_set_center[0], small_set_center[1]), (large_set_center[0], large_set_center[1]))\n    else:\n        return ((large_set_center[0], large_set_center[1]), (small_set_center[0], small_set_center[1]))\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    set1, set2 = find_color_sets(input_grid)\n    small_set, large_set = rename_color_sets(set1, set2)\n    small_set_center, large_set_center = get_color_set_center(small_set, large_set)\n    left, right = get_new_coordinate(small_set_center, large_set_center)\n    up, down = get_new_y_coordinate(small_set_center, large_set_center)\n    direction = judge_set_position(small_set, large_set)\n    if direction == 0:\n        color_black_points_teal(input_grid, up, down, small_set, large_set)\n    elif direction == 1:\n        color_black_points_left_right(input_grid, up, down, small_set, large_set)\n    return output_grid\ndef judge_set_position(small_set: Set[int], large_set: Set[int]) -> int:\n    \"\"\"\n    Given two sets of indices representing cells with non-black colors, this function judges their relative position.\n    Args:\n    - small_set: A set of indices representing cells with one of the two non-black colors.\n    - large_set: A set of indices representing cells with one of the two non-black colors.\n    Returns:\n    - An integer representing the relative position of the two sets. If they are up-down, return 0; if they are left-right, return 1.\n    \"\"\"\n    small_set_center = get_color_set_center(small_set, large_set)\n    large_set_center = get_color_set_center(large_set, small_set)\n    if small_set_center[0] == large_set_center[0]:\n        return 0\n    else:\n        return 1\ndef get_color_set_center(small_set: Set[int], large_set: Set[int]) -> Tuple[int, int]:\n    \"\"\"\n    Given two sets of indices representing cells with non-black colors, this function returns the center of the smaller set.\n    Args:\n    - small_set: A set of indices representing cells with one of the two non-black colors.\n    - large_set: A set of indices representing cells with one of the two non-black colors.\n    Returns:\n    - A tuple of two integers representing the x and y coordinates of the center of the smaller set.\n    \"\"\"\n    x_center = int(np.mean([i % 5 for i in small_set]))\n    y_center = int(np.mean([i // 5 for i in small_set]))\n    return (x_center, y_center)\ndef get_new_coordinate(small_set_center: Tuple[int, int], large_set_center: Tuple[int, int]) -> Tuple[int, int]:\n    \"\"\"\n    Given two tuples of integers representing the x and y coordinates of the centers of two sets, this function returns a new tuple of integers representing the x and y coordinates of a point that is horizontally aligned with the centers of the two sets, with the x coordinate of the smaller set's center coming first.\n    Args:\n    - small_set_center: A tuple of two integers representing the x and y coordinates of the center of the smaller set.\n    - large_set_center: A tuple of two integers representing the x and y coordinates of the center of the larger set.\n    Returns:\n    - A tuple of two integers representing the x and y coordinates of a point that is horizontally aligned with the centers of the two sets, with the x coordinate of the smaller set's center coming first.\n    \"\"\"\n    if small_set_center[0] < large_set_center[0]:\n        return (small_set_center[0], large_set_center[1])\n    else:\n        return (large_set_center[0], small_set_center[1])\ndef rename_color_sets(set1: Set[int], set2: Set[int]) -> Tuple[Set[int], Set[int]]:\n    \"\"\"\n    Given two sets of indices, this function renames them according to their size.\n    Args:\n    - set1: A set of indices.\n    - set2: A set of indices.\n    Returns:\n    - A tuple of two sets, where the first set is the smaller of the two input sets and the second set is the larger of the two input sets.\n    \"\"\"\n    if len(set1) < len(set2):\n        return (set1, set2)\n    else:\n        return (set2, set1)\ndef color_black_points_teal(input_grid: np.ndarray, up: int, down: int, small_set: Set[int], large_set: Set[int]) -> np.ndarray:\n    \"\"\"\n    Color all black points in area [small_set_left+1:small_set_right-1,up:down] teal.\n    Args:\n    - input_grid: A numpy array representing the input grid.\n    - up: An integer representing the y coordinate of the upper bound of the area to color.\n    - down: An integer representing the y coordinate of the lower bound of the area to color.\n    - small_set: A set of indices representing cells with one of the two non-black colors.\n    - large_set: A set of indices representing cells with one of the two non-black colors.\n    Returns:\n    - A numpy array representing the output grid with the specified area colored teal.\n    \"\"\"\n    small_set_left = min([i % 5 for i in small_set])\n    small_set_right = max([i % 5 for i in small_set])\n    for i in range(small_set_left + 1, small_set_right):\n        for j in range(up, dow