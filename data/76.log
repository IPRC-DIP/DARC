eled_array == largest_component)[0])\n    bottom_boundary = np.max(np.where(labeled_array == largest_component)[0])\n    left_boundary = np.min(np.where(labeled_array == largest_component)[1])\n    right_boundary = np.max(np.where(labeled_array == largest_component)[1])\n    largest_matrix = np.zeros_like(input_grid)\n    largest_matrix_size = 0\n    for i in range(top_boundary, bottom_boundary + 1):\n        for j in range(left_boundary, right_boundary + 1):\n            if input_grid[i][j] == c2:\n                matrix = np.zeros_like(input_grid)\n                matrix[i][j] = c2\n                stack = [(i, j)]\n                while stack:\n                    x, y = stack.pop()\n                    if x > 0 and input_grid[x - 1][y] in (c1, c2) and (matrix[x - 1][y] == 0):\n                        matrix[x - 1][y] = input_grid[x - 1][y]\n                        stack.append((x - 1, y))\n                    if x < input_grid.shape[0] - 1 and input_grid[x + 1][y] in (c1, c2) and (matrix[x + 1][y] == 0):\n                        matrix[x + 1][y] = input_grid[x + 1][y]\n                        stack.append((x + 1, y))\n                    if y > 0 and input_grid[x][y - 1] in (c1, c2) and (matrix[x][y - 1] == 0):\n                        matrix[x][y - 1] = input_grid[x][y - 1]\n                        stack.append((x, y - 1))\n                    if y < input_grid.shape[1] - 1 and input_grid[x][y + 1] in (c1, c2) and (matrix[x][y + 1] == 0):\n                        matrix[x][y + 1] = input_grid[x][y + 1]\n                        stack.append((x, y + 1))\n                if np.sum(matrix == c2) > 0 and np.sum(matrix == c1) > 0:\n                    if np.sum(matrix == c1) > largest_matrix_size:\n                        largest_matrix = matrix\n                        largest_matrix_size = np.sum(matrix == c1)\n    largest_matrix[largest_matrix == c1] = yellow\n    return largest_matrix\ndef get_third_most_common_color(input_grid: np.ndarray) -> int:\n    \"\"\"\n 