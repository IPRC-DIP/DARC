f the center pixel of the pattern.\n\n    Returns:\n    A boolean value indicating whether the given color pattern is present in the sub-grid.\n    \"\"\"\n    if sub[i, j] == back:\n        return False\n    for row in range(i - 1, i + 2):\n        for col in range(j - 1, j + 2):\n            if sub[row, col] == back:\n                return False\n    return True\ndef find_most_color(sub1: np.ndarray, sub2: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    Finds the most common color in sub1 and sub2.\n\n    Args:\n    sub1: A numpy array representing the first sub-grid.\n    sub2: A numpy array representing the second sub-grid.\n\n    Returns:\n    A tuple of two integers representing the most common color in sub1 and sub2, respectively.\n    \"\"\"\n    colors1, counts1 = np.unique(sub1, return_counts=True)\n    colors2, counts2 = np.unique(sub2, return_counts=True)\n    back_1 = colors1[np.argmax(counts1)]\n    back_2 = colors2[np.argmax(counts2)]\n    return (back_1, back_2)\ndef match_patterns(sub1: np.ndarray, back_1: int, p1: Tuple[int, int], sub2: np.ndarray, back_2: int, p2: Tuple[int, int]) -> bool:\n    \"\"\"\n    Matches the patterns in sub1 and sub2.\n\n    Args:\n    sub1: A numpy array representing the first sub-grid.\n    back_1: An integer representing the most common color in sub1.\n    p1: A tuple of two integers representing the coordinates of the top-left pixel of the pattern in sub1.\n    sub2: A numpy array representing the second sub-grid.\n    back_2: An integer representing the most common color in sub2.\n    p2: A tuple of two integers representing the coordinates of the top-left pixel of the pattern in sub2.\n\n    Returns:\n    A boolean value indicating whether the patterns in sub1 and sub2 match.\n    \"\"\"\n    for color in set(sub1.flatten()) - {back_1}:\n        if np.sum(sub1 == color) != np.sum(sub2 == color):\n            return False\n        if not np.all(np.where(sub1 == color) - np.array(p1) == np.where(sub2 == color) - np.array(p2)):\n            return False\n    return True", "holes": {"split_grid": "split the input_grid along the horizontal or vertical direction, the 1 of 2 grids should have 4 color when the other has 3", "copy_pattern": "copy the pattern in the sub which has 4 colors to the other sub in the matched position", "check_color_pattern": "use index(i,j) as the center pixel, for any color that is not back color, 3x3 area has some pixels in the color, and pixels around the area is not in the color", "find_most_color": "find the most color in sub1 and sub2", "match_patterns": "match the pattern in p1 and p2, if for any color that is not back color, for 2 patterns, the number of pixels in the color and the relative position between pixels in the color is same, recognize patterns are matched"}}
