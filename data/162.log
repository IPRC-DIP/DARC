{"action": "edit", "code": "def set_black_without_grey(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    Returns a new grid of the same size as input_grid, but with all elements set to black element without grey element.\n    \n    Args:\n    input_grid: A numpy array representing the input grid.\n    \n    Returns:\n    A numpy array representing the output grid.\n    \"\"\"\n    output_grid = np.copy(input_grid)\n    output_grid[output_grid != grey] = black\n    return output_grid\ndef find_3x3_blocks(input_grid: np.ndarray) -> List[np.ndarray]:\n    \"\"\"\n    Returns a list of 3x3 numpy arrays representing the nine 3x3 blocks in input_grid.\n    \n    Args:\n    input_grid: A numpy array representing the input grid.\n    \n    Returns:\n    A list of 3x3 numpy arrays representing the nine 3x3 blocks in input_grid.\n    \"\"\"\n    sub_blocks = []\n    for i in range(0, 9, 3):\n        for j in range(0, 9, 3):\n            sub_blocks.append(input_grid[i:i + 3, j:j + 3])\n    return sub_blocks\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    output_grid = set_black_without_grey(input_grid)\n    sub_blocks = find_3x3_blocks(input_grid)\n    yellow_block, position = find_yellow_block(sub_blocks)\n    output_grid = replace_block_with_yellow(output_grid, yellow_block, position)\n    return output_grid\ndef replace_block_with_yellow(input_grid: np.ndarray, position: int) -> np.ndarray:\n    \"\"\"\n    Returns a new grid of the same size as input_grid, but with the block in the given position replaced with a yellow block.\n    \n    Args:\n    input_grid: A numpy array representing the input grid.\n    position: An integer representing the position of the block to be replaced with a yellow block.\n    \n    Returns:\n    A numpy array representing the output grid.\n    \"\"\"\n    output_grid = np.copy(input_grid)\n    sub_blocks = find_3x3_blocks(input_grid)\n    output_grid[position // 3 * 3:position // 3 * 3 + 3, position % 3 * 3:position % 3 * 3 + 3] = 