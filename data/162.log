{"action": "edit", "code": "def set_black_without_grey(input_grid: np.ndarray) -> np.ndarray:\n    output_grid = np.copy(input_grid)\n    output_grid[output_grid != grey] = black\n    return output_grid\ndef separate_into_sub_blocks(input_grid: np.ndarray) -> List[np.ndarray]:\n    sub_blocks = []\n    for i in range(0, 9):\n        row = i // 3 * 3\n        col = i % 3 * 3\n        sub_block = input_grid[row:row + 3, col:col + 3]\n        sub_blocks.append(sub_block)\n    return sub_blocks\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    output_grid = set_black_without_grey(input_grid)\n    input_grid = remove_grey_elements(input_grid)\n    sub_blocks = separate_into_sub_blocks(input_grid)\n    yellow_block, position = find_yellow_block(sub_blocks)\n    output_grid = replace_yellow_block_with_black_blocks(output_grid, yellow_block, position)\n    return output_grid\ndef find_yellow_block(input_blocks: List[np.ndarray]) -> Tuple[np.ndarray, int]:\n    for i, block in enumerate(input_blocks):\n        if yellow in block:\n            position = np.where(block == yellow)\n            return (block, int(position[0]) * 3 + int(position[1]))\n    return (None, None)\ndef remove_grey_elements(input_grid: np.ndarray) -> np.ndarray:\n    output_grid = np.copy(input_grid)\n    output_grid[output_grid == grey] = 0\n    return output_grid\ndef replace_yellow_block_with_black_blocks(input_grid: np.ndarray, yellow_block: np.ndarray, position: int) -> np.ndarray:\n    sub_blocks = separate_into_sub_blocks(input_grid)\n    sub_blocks[position] = set_black_without_grey(sub_blocks[position])\n    output_grid = np.vstack([np.hstack(sub_blocks[i:i + 3]) for i in range(0, 9, 3)])\n    return output_grid", "user_code": "def main(input_grid: np.ndarray) -> np.ndarray:\n    output_grid = `sme size as input grid, but set all elements to black element without grey element`(input_grid)\n    input_grid = `remove all grey elements in input_grid`(input_grid)\n    sub_blocks = `seperate the