{"action": "input", "code": "def find_connected_pixels(input_grid: np.ndarray, bx: int, by: int, visited: np.ndarray, lx: int, ly: int, sx: int, sy: int) -> Tuple[int, int, int, int]:\n    \"\"\"\n    Starting from (bx, by), search for all contacted non-black blocks in the case of four-connectivity;\n    each time a non-black block is found, recursively search;\n    return the pixel (lx, ly) with the largest coordinates encountered during the search process and\n    Pixel(sx,sy) with the smallest coordinates\n    \"\"\"\n    visited[bx][by] = True\n    if input_grid[bx][by] != black:\n        lx = max(lx, bx)\n        ly = max(ly, by)\n        sx = min(sx, bx)\n        sy = min(sy, by)\n        if bx > 0 and (not visited[bx - 1][by]):\n            lx, ly, sx, sy = find_connected_pixels(input_grid, bx - 1, by, visited, lx, ly, sx, sy)\n        if by > 0 and (not visited[bx][by - 1]):\n            lx, ly, sx, sy = find_connected_pixels(input_grid, bx, by - 1, visited, lx, ly, sx, sy)\n        if bx < input_grid.shape[0] - 1 and (not visited[bx + 1][by]):\n            lx, ly, sx, sy = find_connected_pixels(input_grid, bx + 1, by, visited, lx, ly, sx, sy)\n        if by < input_grid.shape[1] - 1 and (not visited[bx][by + 1]):\n            lx, ly, sx, sy = find_connected_pixels(input_grid, bx, by + 1, visited, lx, ly, sx, sy)\n    return (lx, ly, sx, sy)\ndef main(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    In the input, you should see a n*n grid with multiple color pixels.\n    \"\"\"\n    bx, by = find_teal_surrounded_by_red(input_grid)\n    lx, ly, sx, sy = find_connected_pixels(input_grid, bx, by)\n    sub_grid = extract_subgrid(input_grid, lx, ly, sx, sy)\n    ngrid = np.zeros([sub_grid.shape[0] + 2, sub_grid.shape[1] + 2])\n    ngrid = transform_grid(ngrid, sub_grid)\n    return ngrid\ndef find_teal_surrounded_by_red(input_grid: np.ndarray) -> Tuple[int, int]:\n    \"\"\"\n    This function traverses the entire input grid to find a teal pixel surrounded by at least one red pixel.\n    It returns the coordinates of the pixel (bx, by).\n    \"\"\"\n    for i in range(input_grid.shape[0]):\n        for j in range(input_grid.shape[1]):\n            if input_grid[i][j] == teal:\n                if i > 0 and input_grid[i - 1][j] == red:\n                    return (i, j)\n                elif j > 0 and input_grid[i][j - 1] == red:\n                    return (i, j)\n                elif i < input_grid.shape[0] - 1 and input_grid[i + 1][j] == red:\n                    return (i, j)\n                elif j < input_grid.shape[1] - 1 and input_grid[i][j + 1] == red:\n                    return (i, j)\n    return (-1, -1)\ndef transform_grid(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    In the input, you should see a n*n grid with multiple color pixels.\n    \"\"\"\n    bx, by = find_teal_surrounded_by_red(input_grid)\n    lx, ly, sx, sy = find_connected_pixels(input_grid, bx, by)\n    sub_grid = extract_subgrid(input_grid, lx, ly, sx, sy)\n    ngrid = np.zeros([sub_grid.shape[0] + 2, sub_grid.shape[1] + 2])\n    ngrid[1:-1, 1:-1] = sub_grid\n    ngrid[0][0] = yellow\n    ngrid[0][-1] = yellow\n    ngrid[-1][0] = yellow\n    ngrid[-1][-1] = yellow\n    for i in range(ngrid.shape[0]):\n        if ngrid[i][0] == black:\n            ngrid[i][0] = ngrid[i][1]\n        if ngrid[i][-1] == black:\n            ngrid[i][-1] = ngrid[i][-2]\n    return ngrid\ndef extract_subgrid(input_grid: np.ndarray, lx: int, ly: int, sx: int, sy: int) -> np.ndarray:\n    \"\"\"\n    Extract the subgrid with (sx, sy) as the upper left corner and (lx, ly) as the lower right corner\n    \"\"\"\n    return input_grid[sx:lx + 1, sy:ly + 1]", "user_code": "def main(input_grid: np.ndarray) -> np.ndarray:\n    \"\"\"\n    In the input, you should see a n*n grid with multiple color pixels.\n    \"\"\"\n    (bx,by) = `Traverse the entire input grid to find a teal pixel surrounded by at least one red pixel. returns the coordinates of the pixel (bx, b